  },
  "author": "Hisayuki Ookubo <opaopa6969@gmail.com>",
  "peerDependencies": {
    "react": ">=18",
    "@unlaxer/tramli": ">=3.3.0"
  },
  "devDependencies": {
    "@unlaxer/tramli": "^3.3.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "typescript": "^5.5.0"
  }
}
