{
  "name": "@unlaxer/tramli-plugins",
  "version": "3.7.0",
  "description": "Plugin pack for tramli — audit, eventstore, observability, resume, idempotency, hierarchy, diagram, docs, lint, testing, subflow",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opaopa6969/tramli-ts"
  },
  "author": "Hisayuki Ookubo <opaopa6969@gmail.com>",
  "peerDependencies": {
    "@unlaxer/tramli": ">=3.1.0"
  },
  "devDependencies": {
    "@unlaxer/tramli": "^3.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
