{
  "name": "@unlaxer/tramli-viz",
  "version": "0.2.0",
  "description": "Real-time flow monitoring UI for tramli — fireball traces, heat trails, multi-SM layout",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "build:app": "vite build --mode app"
  },
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.0.0",
    "@xyflow/react": "^12.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opaopa6969/tramli.git",
    "directory": "viz/web"
  },
  "license": "MIT",
  "keywords": ["tramli", "flow", "visualization", "state-machine", "react-flow", "monitoring"]
}
