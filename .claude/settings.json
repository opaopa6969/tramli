{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|write|edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .dre/hooks/post-check.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .dre/hooks/stop-check.sh 2>/dev/null || echo '{\"ok\": true}'"
          }
        ]
      }
    ]
  }
}
