{
  "name": "@unlaxer/dxe-suite",
  "version": "0.1.7",
  "description": "DxE Suite — DGE / DDE / DRE toolkit を一括インストール・管理するスイートパッケージ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opaopa6969/DxE-suite"
  },
  "keywords": [
    "claude-code",
    "claude-config",
    "dge",
    "dde",
    "dre",
    "dxe",
    "llm",
    "suite"
  ],
  "bin": {
    "dxe": "./bin/dxe.js"
  },
  "peerDependencies": {
    "@unlaxer/dge-toolkit": ">=3.0.0",
    "@unlaxer/dde-toolkit": ">=0.1.0",
    "@unlaxer/dre-toolkit": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "@unlaxer/dge-toolkit": {
      "optional": true
    },
    "@unlaxer/dde-toolkit": {
      "optional": true
    },
    "@unlaxer/dre-toolkit": {
      "optional": true
    }
  },
  "scripts": {
    "postinstall": "node -e \"console.log('\\n  DxE Suite installed.\\n  Run: npx dxe install\\n  to set up DGE / DDE / DRE in your project.\\n')\""
  }
}
