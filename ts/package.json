{
  "name": "@unlaxer/tramli",
  "version": "3.4.0",
  "description": "Constrained flow engine — state machines that prevent invalid transitions at build time",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && node scripts/fix-cjs.cjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opaopa6969/tramli-ts"
  },
  "author": "Hisayuki Ookubo <opaopa6969@gmail.com>",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
